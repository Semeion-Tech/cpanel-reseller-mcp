RESELLER_MCP_DB_PATH=/app/data/reseller-mcp.db
RESELLER_MCP_CATALOG_PATH=/app/catalog/live_operations.json
RESELLER_MCP_HOST=0.0.0.0
RESELLER_MCP_PORT=8080
RESELLER_MCP_PUBLIC_URL=https://mcp-reseller.semeiontech.com
RESELLER_MCP_TOKEN_PEPPER=replace-with-64-random-characters
RESELLER_MCP_CONFIRMATION_SECRET=replace-with-another-64-random-characters
RESELLER_MCP_CPANEL_BASE_URL=https://cpanel.example.com:2087
RESELLER_MCP_CPANEL_RESELLER=demo-reseller
RESELLER_MCP_CPANEL_READER_TOKEN=
RESELLER_MCP_CPANEL_OPERATOR_TOKEN=
RESELLER_MCP_CPANEL_ADMIN_TOKEN=
RESELLER_MCP_CPANEL_VERIFY_TLS=true
RESELLER_MCP_AUDIT_RETENTION_DAYS=365
RESELLER_MCP_REQUIRE_SECOND_APPROVER=false
RESELLER_MCP_ALLOW_UNTYPED_ADVANCED=false
RESELLER_MCP_ALLOW_SENSITIVE_FILE_READS=false
RESELLER_MCP_HEALTH_MIN_PHP_VERSION=8.2
# Reserved for the optional memory adapter described in ADR-001. It is disabled by default.
RESELLER_MCP_MEMORY_PROVIDER=none
# RESELLER_MCP_MEM0_ENDPOINT=https://your-semeion-mem0-endpoint
RESELLER_MCP_MEM0_USER_ID=kleber
